# Test environment — used by CI and local test runs
# Copy real values from .env and override as needed
DATABASE_URL=postgresql://smsok:${TEST_DB_PASSWORD}@localhost:5432/smsok_test
REDIS_URL=redis://localhost:6379
JWT_SECRET=${TEST_JWT_SECRET}
ADMIN_JWT_SECRET=${TEST_ADMIN_JWT_SECRET}
TWO_FA_ENCRYPTION_KEY=${TEST_2FA_KEY}
CRON_SECRET=${TEST_CRON_SECRET}
NODE_ENV=test

# E2E test credentials (set in CI secrets or local .env)
E2E_USER_EMAIL=test@example.com
E2E_USER_PASSWORD=${E2E_USER_PASSWORD}
E2E_ADMIN_EMAIL=admin@smsok.com
E2E_ADMIN_PASSWORD=${E2E_ADMIN_PASSWORD}
